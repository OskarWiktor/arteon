{
  "name": "arteon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/fix-bom.cjs",
    "dev": "next dev",
    "prebuild": "node scripts/fix-bom.cjs && node scripts/split-blog.cjs && node scripts/generate-search-index.cjs",
    "build": "next build",
    "postinstall": "node scripts/fix-bom.cjs",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs && node scripts/postbuild-sitemap-hreflang.cjs && node scripts/indexnow-notify.cjs",
    "clear-cache": "node scripts/clear-vercel-cache.cjs",
    "start": "next start",
    "lint": "eslint app --ext .ts,.tsx",
    "format": "prettier --write .",
    "analyze": "ANALYZE=true next build",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "gifenc": "^1.0.3",
    "heic2any": "^0.0.4",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.2.0",
    "marked": "^17.0.3",
    "next": "16.1.6",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "sharp": "^0.34.5",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "utif2": "^4.1.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.1.6",
    "@next/eslint-plugin-next": "16.1.6",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4",
    "tailwindcss-children": "^2.1.0",
    "typescript": "^5"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
