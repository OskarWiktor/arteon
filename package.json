{
  "name": "arteon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/fix-bom.cjs && node scripts/sync-pdf-worker.cjs",
    "dev": "next dev",
    "prebuild": "node scripts/fix-bom.cjs && node scripts/sync-pdf-worker.cjs && node scripts/split-blog.cjs && node scripts/generate-search-index.cjs",
    "build": "next build",
    "postinstall": "node scripts/fix-bom.cjs && node scripts/sync-pdf-worker.cjs",
    "prepare": "husky",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs && node scripts/postbuild-sitemap-hreflang.cjs",
    "clear-cache": "node scripts/clear-vercel-cache.cjs",
    "start": "next start",
    "lint": "eslint .",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "analyze": "node scripts/analyze.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test a11y"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "clsx": "^2.1.1",
    "gifenc": "^1.0.3",
    "heic2any": "^0.0.4",
    "js-yaml": "^4.2.0",
    "jspdf": "^4.2.1",
    "marked": "^17.0.3",
    "next": "^16.2.9",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.5.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.1",
    "tailwind-merge": "^3.6.0",
    "temporal-polyfill": "^0.3.2",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "utif2": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@next/bundle-analyzer": "16.2.9",
    "@next/eslint-plugin-next": "16.2.9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.33.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "eslint-plugin-sonarjs": {
      "minimatch": "^10.2.5"
    },
    "next": {
      "postcss": "$postcss"
    }
  }
}
