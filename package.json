{
  "name": "arteon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node -e \"const fs=require('fs');const p='node_modules/next/dist/compiled/anser/package.json';try{if(!fs.existsSync(p))process.exit(0);const s=fs.readFileSync(p,'utf8');if(s && s.charCodeAt(0)===0xFEFF){fs.writeFileSync(p,s.slice(1),'utf8');}}catch(e){process.exit(0);}\"",
    "dev": "next dev --turbopack",
    "prebuild": "node -e \"const fs=require('fs');const p='node_modules/next/dist/compiled/anser/package.json';try{if(!fs.existsSync(p))process.exit(0);const s=fs.readFileSync(p,'utf8');if(s && s.charCodeAt(0)===0xFEFF){fs.writeFileSync(p,s.slice(1),'utf8');}}catch(e){process.exit(0);}\" && node scripts/generate-search-index.cjs",
    "build": "next build",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/next/dist/compiled/anser/package.json';try{if(!fs.existsSync(p))process.exit(0);const s=fs.readFileSync(p,'utf8');if(s.charCodeAt(0)===0xFEFF){fs.writeFileSync(p,s.slice(1),'utf8');}}catch(e){/* ignore */}\"",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs && node scripts/postbuild-sitemap-hreflang.cjs",
    "start": "next start",
    "lint": "eslint app --ext .ts,.tsx",
    "format": "prettier --write .",
    "analyze": "ANALYZE=true next build",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "next": "^15.3.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^15.3.6",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4",
    "tailwindcss-children": "^2.1.0",
    "typescript": "^5"
  }
}
